# .env.example — copy to .env for local development, never commit .env
# In GitHub Actions, set these as Encrypted Secrets and they are injected as env vars.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Neon (PostgreSQL) ---
# Get from: console.neon.tech → your project → Connection string
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# --- Gmail API ---
# Set up at: console.cloud.google.com → APIs → Gmail API → OAuth credentials
# Then run scripts/gmail_auth.py once locally to generate the refresh token.
GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...

# --- Routing ---
# Email address that receives the weekly digest (typically same Gmail account)
EMAIL_TO=you@example.com

# --- Preferences (plain English) ---
# Free-text role/location/visa preferences, fed to the LLM scorer.
JOB_PREFERENCES=e.g. Senior AI/Solution Architect roles in the EU or UAE (with visa sponsorship).
# LinkedIn profile URL — DISPLAY ONLY in CV/outreach drafts. Never automated.
LINKEDIN_URL=https://www.linkedin.com/in/your-handle/

# --- Optional tuning ---
# Override log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Override max roles in digest (default from profile.yaml)
DIGEST_TOP_N=
